# Base de datos
DB_TYPE=sqlite
DB_DATABASE=db.sqlite
# Cambia a postgres cuando configuren Supabase:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=yourpassword
# DB_DATABASE=agroindustry

# JWT
JWT_SECRET=change_this_to_a_random_secret_in_production
