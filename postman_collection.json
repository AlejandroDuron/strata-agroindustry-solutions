{
  "info": {
    "name": "Strata Agroindustry API",
    "description": "Colección Postman para probar auth, usuarios, insumos y eventos con JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('jwt_token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Users (admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "Persona 4 — Insumos",
      "item": [
        {
          "name": "Registrar Insumo (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Urea 46%\",\n  \"type\": \"FERTILIZANTE\",\n  \"quantity\": 10.5,\n  \"unitCost\": 15.0,\n  \"unit\": \"kg\",\n  \"applicationDate\": \"2026-07-21\",\n  \"notes\": \"Aplicación foliar matutina\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/inputs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "inputs"]
            },
            "description": "Registra un insumo y recalcula el costo del ciclo (reemplaza '2' por el cycleId que desees)."
          }
        },
        {
          "name": "Listar Insumos del Ciclo (GET)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/inputs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "inputs"]
            }
          }
        },
        {
          "name": "Obtener un Insumo (GET)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/inputs/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "inputs", "1"]
            }
          }
        },
        {
          "name": "Actualizar Insumo (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 15.0,\n  \"notes\": \"Cantidad corregida por agrónomo\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/inputs/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "inputs", "1"]
            },
            "description": "Actualiza cantidad/costo y recalcula dinámicamente el costo por manzana del ciclo."
          }
        },
        {
          "name": "Eliminar Insumo (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/inputs/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "inputs", "1"]
            },
            "description": "Elimina el insumo y recalcula restando su valor del costo por manzana del ciclo."
          }
        }
      ]
    },
    {
      "name": "Persona 4 — Eventos",
      "item": [
        {
          "name": "Registrar Evento (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"RIEGO\",\n  \"eventDate\": \"2026-07-21\",\n  \"description\": \"Riego matutino por goteo sector norte\",\n  \"severity\": \"BAJA\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "events"]
            }
          }
        },
        {
          "name": "Listar Eventos del Ciclo (GET)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "events"]
            }
          }
        },
        {
          "name": "Obtener un Evento (GET)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "events", "1"]
            }
          }
        },
        {
          "name": "Actualizar Evento (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Riego matutino extendido a 3 horas\",\n  \"resolvedAt\": \"2026-07-22\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "events", "1"]
            }
          }
        },
        {
          "name": "Eliminar Evento (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/production-cycles/2/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["production-cycles", "2", "events", "1"]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": ""
    }
  ]
}
